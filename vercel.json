{
  "version": 2,
  "installCommand": "composer install --no-dev --no-interaction --no-progress --no-scripts && npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "env": {
    "COMPOSER_MEMORY_LIMIT": "-1",
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "VERCEL_DEBUG": "1",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "LOG_CHANNEL": "stderr",
    "DB_CONNECTION": "sqlite",
    "DB_DATABASE": ":memory:",
    "VIEW_COMPILED_PATH": "/tmp/views"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
